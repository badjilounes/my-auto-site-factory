{
  "name": "prospect-finder",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/prospect-finder/src",
  "projectType": "application",
  "targets": {
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "prospect-finder:build",
        "watch": true
      }
    },
    "build": {
      "executor": "@nx/js:swc",
      "options": {
        "outputPath": "dist/apps/prospect-finder",
        "main": "apps/prospect-finder/src/main.ts",
        "tsConfig": "apps/prospect-finder/tsconfig.json"
      }
    }
  }
}
