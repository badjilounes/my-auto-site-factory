{
  "name": "prospect-finder",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/prospect-finder/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/prospect-finder",
        "main": "apps/prospect-finder/src/main.ts",
        "tsConfig": "apps/prospect-finder/tsconfig.json",
        "compiler": "tsc",
        "target": "node",
        "webpackConfig": "apps/prospect-finder/webpack.config.js"
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "prospect-finder:build",
        "watch": true,
        "args": []
      }
    }
  },
  "tags": ["scope:worker", "type:app"]
}
