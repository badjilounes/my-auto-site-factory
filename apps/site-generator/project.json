{
  "name": "site-generator",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/site-generator/src",
  "projectType": "application",
  "targets": {
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "site-generator:build",
        "watch": true
      }
    },
    "build": {
      "executor": "@nx/js:swc",
      "options": {
        "outputPath": "dist/apps/site-generator",
        "main": "apps/site-generator/src/main.ts",
        "tsConfig": "apps/site-generator/tsconfig.json"
      }
    }
  }
}
