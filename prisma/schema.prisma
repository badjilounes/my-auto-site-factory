generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum ProspectStatus {
  NEW
  ENRICHED
  SITE_GENERATING
  SITE_GENERATED
  SITE_DEPLOYED
  OUTREACH_SENT
  INTERESTED
  CLIENT
  REJECTED
}

enum DeploymentStatus {
  PENDING
  BUILDING
  DEPLOYED
  FAILED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  CANCELLED
  EXPIRED
}

enum SubscriptionPlan {
  MONTHLY
  YEARLY
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum ScrapingSource {
  UBEREATS
  DELIVEROO
  GOOGLE
  WEBSITE
}

enum ScrapingJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum OutreachEmailStatus {
  DRAFT
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  FAILED
}

enum UserRole {
  ADMIN
  CLIENT
}

// ─── Models ─────────────────────────────────────────────────────────────────

/// NextAuth-compatible User model
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          UserRole  @default(CLIENT)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  clientAccount ClientAccount?

  @@index([email])
  @@index([role])
}

/// NextAuth Account (OAuth providers)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/// NextAuth Session
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/// NextAuth verification token (magic links, email verification)
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Business Models ────────────────────────────────────────────────────────

model Prospect {
  id           String         @id @default(cuid())
  businessName String
  ownerName    String?
  email        String?
  phone        String?
  address      String?
  city         String
  postalCode   String?
  website      String?
  uberEatsUrl  String?
  deliverooUrl String?
  logoUrl      String?
  description  String?        @db.Text
  cuisineType  String?
  openingHours Json?
  rating       Float?
  reviewCount  Int?
  priceRange   String?
  source       String?
  sourceUrl    String?
  notes        String?        @db.Text
  status       ProspectStatus @default(NEW)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  generatedSite  GeneratedSite?
  clientAccount  ClientAccount?
  outreachEmails OutreachEmail[]
  scrapingResults ScrapingResult[]

  @@index([status])
  @@index([city])
  @@index([businessName])
  @@index([cuisineType])
  @@index([email])
  @@index([createdAt])
}

model GeneratedSite {
  id                  String           @id @default(cuid())
  prospectId          String           @unique
  template            String
  subdomain           String           @unique
  customDomain        String?          @unique
  content             Json?
  deploymentStatus    DeploymentStatus @default(PENDING)
  deploymentUrl       String?
  vercelProjectId     String?
  vercelDeploymentId  String?
  githubRepoUrl       String?
  repositoryName      String?
  generatedCode       String?          @db.Text
  lastDeployedAt      DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([deploymentStatus])
  @@index([subdomain])
}

model ClientAccount {
  id                   String             @id @default(cuid())
  prospectId           String             @unique
  userId               String?            @unique
  email                String
  businessName         String
  ownerName            String?
  phone                String?
  subscriptionStatus   SubscriptionStatus @default(TRIAL)
  subscriptionPlan     SubscriptionPlan?
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  customDomain         String?
  trialEndsAt          DateTime?
  currentPeriodEndsAt  DateTime?
  isActive             Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  prospect Prospect  @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  invoices Invoice[]

  @@index([subscriptionStatus])
  @@index([stripeCustomerId])
  @@index([email])
}

model Invoice {
  id                   String        @id @default(cuid())
  clientAccountId      String
  stripeInvoiceId      String?       @unique
  stripePaymentIntentId String?      @unique
  amount               Decimal       @db.Decimal(10, 2)
  currency             String        @default("EUR")
  description          String?
  status               InvoiceStatus @default(DRAFT)
  dueDate              DateTime
  paidAt               DateTime?
  pdfUrl               String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  clientAccount ClientAccount @relation(fields: [clientAccountId], references: [id], onDelete: Cascade)

  @@index([clientAccountId])
  @@index([status])
  @@index([dueDate])
}

model ScrapingJob {
  id           String           @id @default(cuid())
  source       ScrapingSource
  city         String
  cuisineType  String?
  query        String?
  maxResults   Int              @default(100)
  status       ScrapingJobStatus @default(PENDING)
  resultsCount Int              @default(0)
  errorMessage String?          @db.Text
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  results ScrapingResult[]

  @@index([status])
  @@index([source])
  @@index([city])
  @@index([createdAt])
}

/// Raw scraping result before reconciliation
model ScrapingResult {
  id           String         @id @default(cuid())
  scrapingJobId String
  prospectId   String?
  source       ScrapingSource
  sourceUrl    String
  rawData      Json
  name         String
  address      String?
  city         String?
  phone        String?
  email        String?
  website      String?
  cuisineType  String?
  rating       Float?
  reviewCount  Int?
  priceRange   String?
  imageUrls    String[]
  scrapedAt    DateTime       @default(now())
  createdAt    DateTime       @default(now())

  scrapingJob ScrapingJob @relation(fields: [scrapingJobId], references: [id], onDelete: Cascade)
  prospect    Prospect?   @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  @@index([scrapingJobId])
  @@index([prospectId])
  @@index([source])
  @@index([name])
}

model OutreachEmail {
  id            String              @id @default(cuid())
  prospectId    String
  to            String
  subject       String
  htmlBody      String              @db.Text
  textBody      String?             @db.Text
  status        OutreachEmailStatus @default(DRAFT)
  scheduledAt   DateTime?
  sentAt        DateTime?
  openedAt      DateTime?
  clickedAt     DateTime?
  resendEmailId String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([prospectId])
  @@index([status])
  @@index([sentAt])
}
